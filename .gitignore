__pycache__/
*.pyc
*.pyo
*.egg-info/
.buildozer/
.DS_Store
.pytest_cache/

# Build outputs
bin/
*.apk
*.aab
*.idsig

# Compiled translation catalogs (auto-generated; .po is the source)
*.mo

# Rendered buildozer.spec (generated by server_apk/build.sh from
# buildozer.spec.tmpl; per-machine env-var substitution)
server_apk/buildozer.spec

# Multi-density presplash variants (generated by generate_presplash.py;
# the script + the unqualified fallback are source-of-truth).
server_apk/presplash_variants/

# Local secrets / runtime state — defense in depth.
# These don't live in the repo today, but never let a careless
# ``git add .`` commit them later.
*.keystore
*.jks
*.pem
*.p12
.env
.env.*
credentials.json
prefs.json
server.json

# Editor / IDE local config
.vscode/
.idea/
*.swp
*.swo
*~

# Claude Code local config (allow-lists, transcripts)
.claude/

# Working notes / scratch — don't commit one-off dumps to a public
# repo. If the content is worth keeping, promote it to docs/.
claud_diffs.txt
*.scratch.txt
agenda.txt
