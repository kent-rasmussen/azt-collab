# ── update.py — self-update flow ──────────────────────────────────────────

msgid "Update this app"
msgstr "Mettre à jour cette application"

msgid "Up to date."
msgstr "À jour."

msgid "Checking for updates…"
msgstr "Recherche de mises à jour…"

