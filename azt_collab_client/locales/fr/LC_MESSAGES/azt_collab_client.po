# ── translate.py — status messages ────────────────────────────────────────

msgid "Initialized git repository."
msgstr "Dépôt git initialisé."

msgid "Repository already initialized."
msgstr "Dépôt déjà initialisé."

msgid "Created .gitignore."
msgstr ".gitignore créé."

