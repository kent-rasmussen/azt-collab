msgstr "Ouvrez votre hébergeur git pour créer une pull request."

msgid "No new audio"
msgstr "Pas de nouveau fichier audio"

msgid "No repo"
msgstr "Aucun dépôt"

msgid "Not a git repository. Publish the project first."
msgstr "Pas un dépôt git. Publiez d'abord le projet."

msgid "No remote configured. Publish the project first."
msgstr "Aucun dépôt distant configuré. Publiez d'abord le projet."

msgid "Commit: {error}"
msgstr "Validation : {error}"

msgid "Push failed: {error}"
msgstr "Échec de l'envoi : {error}"

msgid "Pull failed: {error}"
msgstr "Échec de la récupération : {error}"

msgid "Clone failed: {error}"
msgstr "Échec du clonage : {error}"

msgid "Branch error: {error}"
msgstr "Erreur de branche : {error}"

msgid "Create repo failed: {error}"
msgstr "Échec de la création du dépôt : {error}"

msgid "Not connected to GitHub. Go to Setup > Connect to GitHub."
msgstr "Non connecté à GitHub. Allez dans Configuration > Se connecter à GitHub."

msgid "App not installed. Visit {url} and select \"All repositories\"."
msgstr "Application non installée. Visitez {url} et sélectionnez « Tous les dépôts »."

msgid "App not authorized for {owner_repo}. Add it at {url}"
msgstr "Application non autorisée pour {owner_repo}. Ajoutez-le à {url}"

msgid "Access denied (403). Check app permissions at {url}"
msgstr "Accès refusé (403). Vérifiez les permissions de l'application à {url}"

msgid "Authorization expired. Please try again."
msgstr "Autorisation expirée. Veuillez réessayer."

msgid "Authorization denied by user."
msgstr "Autorisation refusée par l'utilisateur."

msgid "Authorization timed out."
msgstr "Délai d'autorisation dépassé."

msgid "Another sync is in progress. Try again in a moment."
msgstr "Une autre synchronisation est en cours. Réessayez dans un instant."

msgid "Merge conflicts in {paths}"
msgstr "Conflits de fusion dans {paths}"

msgid "Merge conflicts; review the entries flagged azt-lift-conflict."
msgstr "Conflits de fusion ; vérifiez les entrées marquées azt-lift-conflict."

msgid "Sync service unavailable: {error}"
msgstr "Service de synchronisation indisponible : {error}"

msgid "Sync service error: {error}"
msgstr "Erreur du service de synchronisation : {error}"

msgid "Clone failed — repository not found. This may be a private repository.\n\nAre you authenticated to {host}?"
msgstr "Échec du clonage — dépôt introuvable. Il peut s'agir d'un dépôt privé.\n\nÊtes-vous authentifié auprès de {host} ?"

