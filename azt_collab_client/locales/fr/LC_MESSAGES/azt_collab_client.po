msgstr "Envoyé vers {url} (branche : {branch})."

msgid "Pushed to {branch}."
msgstr "Envoyé vers {branch}."

msgid "Pushed."
msgstr "Envoyé."

msgid "Pulled latest changes."
msgstr "Dernières modifications récupérées."

msgid "Cloned to {dir}"
msgstr "Cloné dans {dir}"

msgid "Found: {file}"
msgstr "Trouvé : {file}"

