# =============================================================================
#                            EDIT THIS FILE
#
#   This is the SOURCE template for the AZT Collaboration server APK
#   buildozer config. Every build-time configuration change goes here.
#
#   When you change something here, or in one of the vaiables below
#   (and only then), run build_buildozer_spec.sh to rebuild 
#   the buildozer.spec file, by substituting ``${VAR}`` placeholders 
#   with env-var values. That rendered spec is generated per-machine, 
#   gitignored, and recreated on every ``build_buildozer_spec.sh`` 
#   invocation — DO NOT edit it; your changes will be clobbered.
#
#   Workflow:
#       1. Edit this file (buildozer.spec.tmpl).
#       2. Run ``build_buildozer_spec.sh``
#
#   Required env vars (build.sh validates):
#       P4A_HOOK                — absolute path to p4a_hook.py
#       P4A_LOCAL_RECIPES       — absolute path to the local-recipes dir
#       AZT_BUILDOZER_BUILDDIR  — absolute path to the buildozer cache
#                                 (e.g. /home/you/AZT/.buildozer)
#
#   Release-signing env vars (only for ``buildozer android release``;
#   p4a consumes these directly, no spec entry — see signing comment
#   further down):
#       P4A_RELEASE_KEYSTORE
#       P4A_RELEASE_KEYALIAS
#       P4A_RELEASE_KEYSTORE_PASSWD
#       P4A_RELEASE_KEYALIAS_PASSWD
# =============================================================================

[app]

# AZT Collaboration service — single-purpose APK that owns $AZT_HOME on
# Android and exposes the daemon to sibling AZT suite apps via
# AZTCollabProvider. Peer APKs (recorder, sister apps) become pure
# ContentProvider clients of this APK; see README_NewClient.txt.

title = AZT Collaboration
package.name = aztcollab
package.domain = org.atoznback
icon.filename = %(source.dir)s/icons/icon.png
icon.adaptive_foreground.filename = %(source.dir)s/icons/icon_adaptive_fg.png
icon.adaptive_background.filename = %(source.dir)s/icons/icon_adaptive_bg.png

presplash.filename = %(source.dir)s/presplash.png
android.presplash_color = #8cd9bf

# Multi-density presplash. Each variant is rendered at native bucket
# size by generate_presplash.py (re-run before build if appinfo / icon /
# theme / version changed). Android's resource resolver picks the
# matching bucket at install/run time; the unqualified
# ``presplash.filename`` above stays as the rare-fallback for devices
# that match no bucket.
#
# Rationale lives in NOTES_TO_DAEMON.md "be eager when you have room
# to" §9: doing the resize in the build keeps the cost off the device,
# instead of asking budget phones to PIL-rescale a single oversized
# asset on first boot.
android.add_resources =
    %(source.dir)s/presplash_variants/drawable-ldpi/presplash.png:drawable-ldpi/presplash.png,
    %(source.dir)s/presplash_variants/drawable-mdpi/presplash.png:drawable-mdpi/presplash.png,
    %(source.dir)s/presplash_variants/drawable-hdpi/presplash.png:drawable-hdpi/presplash.png,
    %(source.dir)s/presplash_variants/drawable-xhdpi/presplash.png:drawable-xhdpi/presplash.png,
    %(source.dir)s/presplash_variants/drawable-xxhdpi/presplash.png:drawable-xxhdpi/presplash.png,
    %(source.dir)s/presplash_variants/drawable-xxxhdpi/presplash.png:drawable-xxxhdpi/presplash.png

source.dir = .
# We pull the daemon and client from sibling directories. Buildozer
# resolves these paths at packaging time, then the resulting APK
# bundles both packages alongside server_apk/main.py.
# Extensions: py (code) + xml (manifest extras) + gz (langtags_mini.json.gz
# under azt_collab_client/ui/assets/) + png (azt_collab_client/azt.png,
# referenced by azt_collabd/ui/picker_app.py as App.icon).
source.include_patterns = main.py,service.py
# po/mo: gettext catalogs under azt_collab_client/locales/<lang>/LC_MESSAGES.
# Without these the device's available_languages() finds nothing and the
# settings UI only offers English.
# json: azt_collabd/data/cawl/<owner>/<repo>/index.json — CAWL
# index seed assets, copied into $AZT_HOME/cawl/ on first
# daemon access for that repo if no cache file exists yet.
# Closes install-day-no-network for index lookup.
source.include_exts = py,xml,gz,png,po,mo,json

# Maintainer / desktop-only scripts that get swept up by the
# include_exts glob but have no business living in the on-device
# APK. Each line documents what it is and why it's excluded.
source.exclude_patterns =
    test_install.py,
    azt_collabd/data/cawl/generate_seed.py

version.regex = __version__ = ['"](.*)['"]
# Single source of truth for the suite version: see the comment block
# at the top of ``azt_collabd/__init__.py``. The literal ``__version__
# = "X.Y.Z"`` lives in ``azt_collab_client/__init__.py``; the daemon
# re-exports it. Buildozer reads the literal from the client package
# so the APK version is unambiguously the one place both Python
# imports resolve to.
version.filename = %(source.dir)s/../azt_collab_client/__init__.py

requirements = python3,kivy,pyjnius,dulwich,certifi,urllib3,typing_extensions,segno,cryptography,zeroconf
# segno: pure-Python QR-code generator (~50 KB, no native deps).
# Used by the daemon UI's "Share repo" popup to render the repo
# URL as a QR for pairing with another device. PNG output uses
# Pillow which is already pulled in via kivy.
# cryptography: ed25519 keypair + self-signed X.509 cert generation
# for the LAN sync transport (``azt_collabd.peer_id``). Phase 1 of
# the parked design in ``docs/local_lan_sync_stub.md``; identity
# files are created lazily on first ``GET /v1/lan/peer_id`` so the
# cost is only paid by users who actually engage LAN sync.
# zeroconf: pure-Python mDNS/DNS-SD library, used on the desktop
# side of ``azt_collabd.lan_discovery``. On Android the daemon
# prefers ``NsdManager`` via pyjnius (FLAG_SHOW_PICKER dodges the
# Android 17 ACCESS_LOCAL_NETWORK runtime permission), but the
# zeroconf import on Android is harmless — it's never called.
# Pulled in via path symlink at packaging time. (See setup.sh in this
# directory for the symlink dance — we mirror the sister-app pattern
# documented in README.md so the server APK source tree contains
# azt_collabd/ + azt_collab_client/ as siblings of main.py.)

orientation = portrait
fullscreen = 0

# Identity of this APK. Peer APKs probe for exactly this package name
# / authority — see azt_collab_client/transports/android_cp.py.
android.package = org.atoznback.aztcollab
p4a.branch = master
# The hook + local recipes live in a sibling repo (buildozer_tweaks/)
# that maintainers check out next to this one. Set the env vars
# P4A_HOOK and P4A_LOCAL_RECIPES; build.sh substitutes here.
p4a.hook = ${P4A_HOOK}
p4a.local_recipes = ${P4A_LOCAL_RECIPES}
android.api = 36
#was 33
android.minapi = 26
#was 21
android.archs = arm64-v8a, armeabi-v7a
#p4a.develop:
android.ndk = 29
#p4a.master:
#android.ndk = 27

# Custom suite signature permission. Same name and signature as
# every peer APK. Without that match, install-time grant is denied
# and peers cannot reach this provider — desired failure mode. The
# same permission gates bindService against AZTServiceProviderhost.
android.permissions = INTERNET, REQUEST_INSTALL_PACKAGES, CAMERA, FOREGROUND_SERVICE, FOREGROUND_SERVICE_SPECIAL_USE, CHANGE_WIFI_MULTICAST_STATE, ACCESS_WIFI_STATE, WAKE_LOCK, org.atoznback.AZT_COLLAB_ACCESS
# CAMERA: required by the picker's "Scan QR to clone" affordance,
# which dispatches to ZXing's CaptureActivity. ZXing requests the
# runtime grant itself at launch; we only need the manifest entry.
# FOREGROUND_SERVICE + FOREGROUND_SERVICE_SPECIAL_USE: required to
# promote the :provider service to a foreground service while the
# LAN sync toggle is on (parked design, phase 4). The "specialUse"
# subtype is "lan-peer-git-sync" — declared in the manifest via
# p4a_hook.py's _AZTCOLLAB_SERVICE_BLOCK once it carries the
# foregroundServiceType + inner <property> attributes (TODO in
# ~/bin/raspy/buildozer_tweaks/p4a_hook.py).
# CHANGE_WIFI_MULTICAST_STATE + ACCESS_WIFI_STATE: required by
# NsdManager advertise/browse + the WifiManager.MulticastLock the
# daemon acquires on toggle-on (phase 5). Without the multicast
# permission the system silently drops mDNS packets in either
# direction even though the API returns success.
# WAKE_LOCK: required by ``WifiManager.WifiLock.acquire()`` —
# the high-perf WifiLock is the actual battery-cost knob behind
# the LAN sync toggle; without WAKE_LOCK, jnius raises
# SecurityException on acquire and the listener falls back to
# whatever Wi-Fi power state the OS happens to be in (multicast
# unreliable, idle drops connections).

# zxing-android-embedded: powers the picker's QR-scan-to-clone
# button. ~500 KB AAR; lives in the server APK because the
# picker subprocess (which owns the clone flow) runs as an
# Activity here.
#
# Its AndroidX deps (fragment, appcompat) are declared in the
# library's POM as ``implementation``, NOT ``api``, so they don't
# bleed into the consuming APK transitively — Gradle resolves them
# at compile time inside the AAR but does NOT add them to our dex.
# The journeyapps classes then reference Fragment / FragmentActivity
# / AppCompatActivity, the Android verifier can't load them at
# runtime, and ``autoclass('com.google.zxing.integration.android.IntentIntegrator')``
# fails with NoClassDefFoundError on Landroidx/fragment/app/Fragment.
# Listing the AndroidX deps explicitly here forces Gradle to pull
# them into the project classpath and thus into classes.dex.
#
# Kotlin stdlib pins resolve a duplicate-class clash: androidx
# fragment 1.6.2 → lifecycle-runtime 2.6.2 pulls kotlin-stdlib 1.8.20
# (post-merge, contains jdk7+jdk8 classes), but the same lifecycle-
# runtime → kotlinx-coroutines-android 1.6.4 transitively pulls
# kotlin-stdlib-jdk{7,8}:1.6.21 (pre-merge, also ships those classes).
# Result: ``Duplicate class kotlin.collections.jdk8.CollectionsJDK8Kt``
# at ``:checkReleaseDuplicateClasses``. Pinning the -jdk7/-jdk8
# artifacts to 1.8.20 routes the transitive request to the empty
# metadata-only redirect artifacts that Kotlin started shipping at
# 1.8 when those packages were merged into kotlin-stdlib proper.
android.gradle_dependencies = com.journeyapps:zxing-android-embedded:4.3.0,androidx.appcompat:appcompat:1.6.1,androidx.fragment:fragment:1.6.2,org.jetbrains.kotlin:kotlin-stdlib:1.8.20,org.jetbrains.kotlin:kotlin-stdlib-jdk7:1.8.20,org.jetbrains.kotlin:kotlin-stdlib-jdk8:1.8.20

# ContentProvider + sticky-bound service declarations.
# Note: buildozer's key is `extra_manifest_xml` (NOT `manifest_extra_xml`,
# which buildozer silently ignores). Content from this file is inlined
# into p4a's --extra-manifest-xml and lands at top-level under
# <manifest>, so this file may only contain top-level elements
# (<permission>, <queries>, ...). The <provider> and <service>
# declarations that belong inside <application> are injected by the
# _inject_aztcollab_provider and _inject_aztcollab_service steps in
# p4a_hook.py.
android.extra_manifest_xml = %(source.dir)s/manifest_extras.xml

# Suite Java glue is bundled here so peers don't have to ship it.
# Holds AZTCollabProvider.java (provider class) and
# AZTServiceProviderhost.java (sticky-bound service class). Peer APKs
# also compile these but only the server APK declares them in its
# manifest — the unused classes are harmless ballast.
android.add_src = ../android/src/main/java

# Sign with the suite keystore — same key as every peer APK.
# Force apk (not aab) so a) we can sideload via the bootstrap
# updater, and b) the keystore-signed output is verifiable against
# android/SUITE_FINGERPRINT directly.
#
# Signing config is **not** in this spec. The ``android.signing.*``
# keys that buildozer historically supported are ignored on the APK
# release path we use — confirmed empirically: the spec entry alone
# does not produce a signed APK. p4a consumes env vars instead.
# See the env-var list at the top of this file.
android.release_artifact = apk

[buildozer]

log_level = 2
warn_on_root = 0
build_dir = ${AZT_BUILDOZER_BUILDDIR}
